{
  "entity_type": "medecin_individuel",
  "name": "Medical Doctor License Schema",
  "required_fields": [
    "nom",
    "spécialité",
    "numéro d'inscription",
    "date de validité"
  ],
  "weights": {
    "nom": 0.3,
    "spécialité": 0.25,
    "numéro d'inscription": 0.25,
    "date de validité": 0.2
  },
  "field_rules": {
    "nom": {
      "type": "string",
      "min_length": 3
    },
    "spécialité": {
      "type": "string",
      "min_length": 3
    },
    "numéro d'inscription": {
      "type": "string",
      "min_length": 5
    },
    "date de validité": {
      "type": "string",
      "pattern": "\\d{4}-\\d{2}-\\d{2}|\\d{2}/\\d{2}/\\d{4}"
    }
  }
}
